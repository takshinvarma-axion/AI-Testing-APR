# Copy to `.env` and fill in as needed. Never commit the real .env.

# --- Provider selection -----------------------------------------------------
# "ollama" (default — local, no key) | "openai" | "anthropic"
PROVIDER=ollama

# Model override (optional)
#   Ollama:    llama3.2:3b  (default)   |   qwen2.5-coder:3b
#   OpenAI:    gpt-4o-mini
#   Anthropic: claude-sonnet-4-6
# DEMO_MODEL=llama3.2:3b

# --- Ollama ----------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- API keys (only if switching providers) --------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
